# Database
DATABASE_URL="postgresql://inboxfm:inboxfm_dev@localhost:5432/inboxfm"

# Redis (Bull)
REDIS_HOST="localhost"
REDIS_PORT=6379

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# Gemini AI / Google AI Studio (Support for up to 3 keys for rotation & fallback rate-limit safety)
GOOGLE_AI_API_KEY="your-gemini-api-key-1"
GOOGLE_AI_API_KEY_2="your-gemini-api-key-2"
GOOGLE_AI_API_KEY_3="your-gemini-api-key-3"
# Alternative config names for Key 1, 2, & 3
GEMINI_API_KEY="your-gemini-api-key-1"
GEMINI_API_KEY_2="your-gemini-api-key-2"
GEMINI_API_KEY_3="your-gemini-api-key-3"

GEMINI_TEXT_MODEL="gemini-3.1-pro-preview"
GEMINI_TTS_MODEL="gemini-3.1-flash-tts-preview"

# Sarvam AI
SARVAM_API_KEY="your-sarvam-api-key"

# S3-compatible storage (audio files)
S3_BUCKET_NAME="your-bucket-name"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your-s3-access-key-id"
S3_SECRET_ACCESS_KEY="your-s3-secret-access-key"
# Optional for S3-compatible storage (e.g., MinIO/local)
S3_ENDPOINT="http://localhost:9000"
S3_FORCE_PATH_STYLE="true"

# JWT
JWT_SECRET="your-32-character-jwt-secret-here"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
APP_URL="http://localhost:3001"

# Resend (transactional email)
RESEND_API_KEY="re_your_resend_api_key"

# Gmail
GMAIL_FETCH_LIMIT=200

# Webhook Security (for CI/CD release notifications)
WEBHOOK_SECRET="your-32-character-webhook-secret-here"

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# Encryption (must be exactly 32 characters)
ENCRYPTION_KEY="your-32-character-encryption-key-here"

# Web Push Notifications (VAPID keys)
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:noreply@vedlabs.tech"

# Sentry (optional)
SENTRY_DSN=""
